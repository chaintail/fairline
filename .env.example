# All optional — replay mode runs with none of these set.

# Ed25519 signing key (base64 PKCS8). Mint one: node scripts/generate-keypair.mjs
# Unset -> feed publishes unsigned envelopes, honestly marked.
FAIRLINE_SIGNING_KEY=

# TxLINE free World Cup tier credentials (see docs/txline.md for the
# on-chain activation flow). Unset -> live mode returns 503, replay unaffected.
TXLINE_API_TOKEN=
TXLINE_JWT=
TXLINE_FIXTURE_ID=18257739
TXLINE_PARTICIPANT1=Spain
TXLINE_PARTICIPANT2=Argentina
